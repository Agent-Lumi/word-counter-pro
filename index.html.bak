<!DOCTYPE html>
<html lang="en">
<head><link rel="manifest" href="manifest.json"><script>if("serviceWorker"in navigator)navigator.serviceWorker.register("sw.js")</script><link rel="manifest" href="manifest.json"><script>if("serviceWorker"in navigator)navigator.serviceWorker.register("sw.js")</script><link rel="manifest" href="manifest.json"><script>if("serviceWorker"in navigator)navigator.serviceWorker.register("sw.js")</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Word Counter Pro - Advanced Text Analysis</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
        }
        header {
            text-align: center;
            color: white;
            padding: 40px 0;
        }
        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        header p {
            opacity: 0.9;
            font-size: 1.1em;
        }
        .main-card {
            background: white;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }
        .input-section {
            margin-bottom: 25px;
        }
        textarea {
            width: 100%;
            min-height: 200px;
            padding: 15px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 1em;
            font-family: inherit;
            resize: vertical;
            transition: border-color 0.2s;
        }
        textarea:focus {
            outline: none;
            border-color: #667eea;
        }
        .options {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }
        .option-btn {
            padding: 10px 20px;
            border: 2px solid #e5e7eb;
            background: white;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.2s;
        }
        .option-btn:hover, .option-btn.active {
            border-color: #667eea;
            background: #f3f4ff;
            color: #667eea;
        }
        .analyze-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.1em;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .analyze-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
        }
        .results {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-top: 25px;
        }
        .stat-card {
            background: #f9fafb;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }
        .stat-value {
            font-size: 2em;
            font-weight: 700;
            color: #667eea;
        }
        .stat-label {
            color: #6b7280;
            font-size: 0.9em;
            margin-top: 5px;
        }
        .keyword-section {
            margin-top: 25px;
            padding-top: 25px;
            border-top: 1px solid #e5e7eb;
        }
        .keyword-section h3 {
            margin-bottom: 20px;
            color: #1f2937;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .keyword-section h3 .icon {
            font-size: 1.2em;
        }
        .keyword-density-container {
            background: #f9fafb;
            border-radius: 12px;
            padding: 20px;
        }
        .keyword-density-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e5e7eb;
        }
        .keyword-density-header h4 {
            color: #374151;
            font-size: 0.95em;
        }
        .total-words-badge {
            background: #667eea;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 500;
        }
        .keyword-bar-item {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
            gap: 12px;
        }
        .keyword-bar-item:last-child {
            margin-bottom: 0;
        }
        .keyword-label {
            min-width: 120px;
            font-weight: 500;
            color: #374151;
            font-size: 0.9em;
            text-transform: lowercase;
        }
        .keyword-bar-wrapper {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .keyword-bar {
            height: 24px;
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            border-radius: 12px;
            transition: width 0.5s ease-out;
            position: relative;
        }
        .keyword-bar-bg {
            flex: 1;
            height: 24px;
            background: #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
        }
        .keyword-stats {
            display: flex;
            gap: 15px;
            font-size: 0.85em;
            color: #6b7280;
            min-width: 100px;
            justify-content: flex-end;
        }
        .keyword-count {
            font-weight: 600;
            color: #667eea;
        }
        .keyword-percent {
            font-weight: 500;
            color: #10b981;
        }
        .keywords-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 15px;
        }
        .keyword-tag {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.9em;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .keyword-tag .count {
            background: rgba(255,255,255,0.2);
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 0.8em;
        }
        .view-toggle {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }
        .view-btn {
            padding: 8px 16px;
            border: 2px solid #e5e7eb;
            background: white;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9em;
            font-weight: 500;
            transition: all 0.2s;
        }
        .view-btn:hover, .view-btn.active {
            border-color: #667eea;
            background: #f3f4ff;
            color: #667eea;
        }
        .view-content {
            display: none;
        }
        .view-content.active {
            display: block;
        }
        .no-keywords {
            text-align: center;
            color: #6b7280;
            padding: 30px;
            font-style: italic;
        }
        .reading-time {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 12px;
            margin-top: 20px;
            text-align: center;
        }
        .reading-time .time {
            font-size: 1.8em;
            font-weight: 700;
        }
        footer {
            text-align: center;
            color: white;
            padding: 30px;
            opacity: 0.8;
        }
        footer a {
            color: white;
        }
        @media (max-width: 600px) {
            header h1 { font-size: 1.8em; }
            .results { grid-template-columns: repeat(2, 1fr); }
            .keyword-label { min-width: 80px; font-size: 0.8em; }
            .keyword-stats { min-width: 80px; font-size: 0.75em; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>📝 Word Counter Pro</h1>
            <p>Advanced text analysis with reading time & keyword density</p>
        </header>
        
        <div class="main-card">
            <div class="input-section">
                <textarea id="textInput" placeholder="Paste or type your text here..."></textarea>
            </div>
            
            <div class="options">
                <button class="option-btn active" onclick="setMode('words')">Words</button>
                <button class="option-btn" onclick="setMode('chars')">Characters</button>
                <button class="option-btn" onclick="setMode('sentences')">Sentences</button>
                <button class="option-btn" onclick="setMode('paragraphs')">Paragraphs</button>
            </div>
            
            <button class="analyze-btn" onclick="analyzeText()">🔍 Analyze Text</button>
            
            <div id="results" class="results" style="display: none;">
                <div class="stat-card">
                    <div class="stat-value" id="wordCount">0</div>
                    <div class="stat-label">Words</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="charCount">0</div>
                    <div class="stat-label">Characters</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="sentenceCount">0</div>
                    <div class="stat-label">Sentences</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="paragraphCount">0</div>
                    <div class="stat-label">Paragraphs</div>
                </div>
            </div>
            
            <div id="readingTime" class="reading-time" style="display: none;">
                <div class="time" id="readTimeValue">0 min read</div>
                <div>Based on average reading speed (200 WPM)</div>
            </div>
            
            <div id="keywordSection" class="keyword-section" style="display: none;">
                <h3><span class="icon">📊</span> Keyword Density Analysis</h3>
                
                <div class="keyword-density-container">
                    <div class="keyword-density-header">
                        <h4>Top 10 Keywords (excluding stop words)</h4>
                        <span class="total-words-badge" id="totalWordsBadge">0 words</span>
                    </div>
                    
                    <div class="view-toggle">
                        <button class="view-btn active" onclick="setView('chart')">📊 Bar Chart</button>
                        <button class="view-btn" onclick="setView('list')">📝 List View</button>
                    </div>
                    
                    <div id="chartView" class="view-content active">
                        <div id="keywordBars"></div>
                    </div>
                    
                    <div id="listView" class="view-content">
                        <div class="keywords-list" id="keywordsList"></div>
                    </div>
                </div>
            </div>
        </div>
        
        <footer>
            <p>Made with 💡 by <a href="https://github.com/Agent-Lumi">Lumi</a> for @shalkith</p>
        </footer>
    </div>
    
    <script>
        let currentMode = 'words';
        let currentView = 'chart';
        
        // Comprehensive list of English stop words
        const STOP_WORDS = new Set([
            // Articles
            'a', 'an', 'the',
            // Prepositions
            'about', 'above', 'across', 'after', 'against', 'along', 'among', 'around', 'at', 'before', 
            'behind', 'below', 'beneath', 'beside', 'between', 'beyond', 'by', 'down', 'during', 
            'except', 'for', 'from', 'in', 'inside', 'into', 'like', 'near', 'of', 'off', 'on', 
            'onto', 'out', 'outside', 'over', 'past', 'since', 'through', 'throughout', 'till', 
            'to', 'toward', 'under', 'underneath', 'until', 'up', 'upon', 'with', 'within', 'without',
            // Conjunctions
            'and', 'but', 'or', 'yet', 'so', 'although', 'because', 'since', 'unless', 'while', 
            'where', 'if', 'than', 'as', 'once', 'till', 'until',
            // Pronouns
            'i', 'me', 'my', 'myself', 'we', 'our', 'ours', 'ourselves', 'you', 'your', 'yours', 
            'yourself', 'yourselves', 'he', 'him', 'his', 'himself', 'she', 'her', 'hers', 
            'herself', 'it', 'its', 'itself', 'they', 'them', 'their', 'theirs', 'themselves', 
            'what', 'which', 'who', 'whom', 'whose', 'this', 'that', 'these', 'those',
            // Auxiliary/Modal Verbs
            'am', 'is', 'are', 'was', 'were', 'be', 'been', 'being', 'have', 'has', 'had', 'do', 
            'does', 'did', 'will', 'would', 'shall', 'should', 'may', 'might', 'must', 'can', 
            'could', 'need', 'dare', 'ought', 'used', 'won', 'wouldn', 'shan', 'shouldn', 'aren', 
            'wasn', 'weren', 'haven', 'hasn', 'hadn', 'don', 'doesn', 'didn', 'can', 'couldn',
            // Common Adverbs/Adjectives
            'just', 'now', 'then', 'here', 'there', 'when', 'where', 'why', 'how', 'all', 'any', 
            'both', 'each', 'few', 'more', 'most', 'other', 'some', 'such', 'no', 'nor', 'not', 
            'only', 'own', 'same', 'very', 'too', 'also', 'back', 'still', 'even', 'much', 'many',
            // Other common words
            'get', 'got', 'go', 'went', 'going', 'gone', 'make', 'made', 'take', 'took', 'taken',
            'come', 'came', 'see', 'saw', 'seen', 'know', 'knew', 'known', 'think', 'thought',
            'say', 'said', 'tell', 'told', 'ask', 'asked', 'work', 'worked', 'try', 'tried',
            'want', 'wanted', 'use', 'used', 'find', 'found', 'give', 'gave', 'given', 'put',
            'let', 'lets', 'way', 'ways', 'time', 'times', 'day', 'days', 'year', 'years',
            'man', 'men', 'woman', 'women', 'people', 'person', 'thing', 'things', 'part', 'parts'
        ]);
        
        function setMode(mode) {
            currentMode = mode;
            document.querySelectorAll('.option-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
        }
        
        function setView(view) {
            currentView = view;
            document.querySelectorAll('.view-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            document.querySelectorAll('.view-content').forEach(content => {
                content.classList.remove('active');
            });
            document.getElementById(view + 'View').classList.add('active');
        }
        
        function analyzeText() {
            const text = document.getElementById('textInput').value.trim();
            
            if (!text) {
                alert('Please enter some text to analyze');
                return;
            }
            
            // Count statistics
            const words = text.split(/\s+/).filter(w => w.length > 0).length;
            const chars = text.length;
            const charsNoSpaces = text.replace(/\s/g, '').length;
            const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0).length;
            const paragraphs = text.split(/\n\n+/).filter(p => p.trim().length > 0).length;
            
            // Update display
            document.getElementById('wordCount').textContent = words.toLocaleString();
            document.getElementById('charCount').textContent = chars.toLocaleString();
            document.getElementById('sentenceCount').textContent = sentences.toLocaleString();
            document.getElementById('paragraphCount').textContent = paragraphs.toLocaleString();
            
            // Show results
            document.getElementById('results').style.display = 'grid';
            
            // Calculate reading time
            const minutes = Math.ceil(words / 200);
            const timeText = minutes < 1 ? '< 1 min read' : minutes + ' min read';
            document.getElementById('readTimeValue').textContent = timeText;
            document.getElementById('readingTime').style.display = 'block';
            
            // Extract and display keyword density
            const keywordData = extractKeywords(text);
            displayKeywordDensity(keywordData, words);
        }
        
        function extractKeywords(text) {
            // Clean and tokenize text
            const words = text.toLowerCase()
                .replace(/[^a-zA-Z\s]/g, ' ')  // Replace non-letters with spaces
                .split(/\s+/)                 // Split on whitespace
                .filter(word => {
                    // Filter conditions:
                    // 1. Must be at least 3 characters
                    // 2. Must not be a stop word
                    // 3. Must contain only letters
                    return word.length >= 3 && 
                           !STOP_WORDS.has(word) &&
                           !STOP_WORDS.has(word.replace(/[^a-z]/g, ''));
                });
            
            // Count frequency
            const frequency = {};
            words.forEach(word => {
                frequency[word] = (frequency[word] || 0) + 1;
            });
            
            // Sort by frequency and get top 10
            const sorted = Object.entries(frequency)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 10);
            
            return {
                keywords: sorted,
                totalFilteredWords: words.length
            };
        }
        
        function displayKeywordDensity(data, totalWords) {
            const { keywords } = data;
            
            // Update total words badge
            document.getElementById('totalWordsBadge').textContent = 
                `${totalWords.toLocaleString()} total words`;
            
            // Get max count for bar scaling
            const maxCount = keywords.length > 0 ? keywords[0][1] : 0;
            
            // Generate bar chart
            const barsContainer = document.getElementById('keywordBars');
            barsContainer.innerHTML = '';
            
            if (keywords.length === 0) {
                barsContainer.innerHTML = '<div class="no-keywords">No significant keywords found. Try entering more text.</div>';
            } else {
                keywords.forEach(([word, count]) => {
                    const percentage = ((count / totalWords) * 100).toFixed(1);
                    const barWidth = maxCount > 0 ? (count / maxCount) * 100 : 0;
                    
                    const barItem = document.createElement('div');
                    barItem.className = 'keyword-bar-item';
                    barItem.innerHTML = `
                        <div class="keyword-label">${word}</div>
                        <div class="keyword-bar-wrapper">
                            <div class="keyword-bar-bg">
                                <div class="keyword-bar" style="width: ${barWidth}%"></div>
                            </div>
                        </div>
                        <div class="keyword-stats">
                            <span class="keyword-count">${count}</span>
                            <span class="keyword-percent">${percentage}%</span>
                        </div>
                    `;
                    barsContainer.appendChild(barItem);
                });
            }
            
            // Generate list view
            const listContainer = document.getElementById('keywordsList');
            listContainer.innerHTML = '';
            
            if (keywords.length === 0) {
                listContainer.innerHTML = '<div class="no-keywords">No significant keywords found. Try entering more text.</div>';
            } else {
                keywords.forEach(([word, count]) => {
                    const percentage = ((count / totalWords) * 100).toFixed(1);
                    const tag = document.createElement('div');
                    tag.className = 'keyword-tag';
                    tag.innerHTML = `${word} <span class="count">${count} (${percentage}%)</span>`;
                    listContainer.appendChild(tag);
                });
            }
            
            // Show the section
            document.getElementById('keywordSection').style.display = 'block';
        }
        
        // Auto-analyze on paste
        document.getElementById('textInput').addEventListener('paste', () => {
            setTimeout(analyzeText, 100);
        });
    </script>
</body>
</html>
<script>
// API integration ready
const API = {
    async fetch(url, options = {}) {
        const response = await fetch(url, options);
        return response.json();
    }
};
</script>
<script>
// Dark mode toggle
const darkModeToggle = document.createElement('button');
darkModeToggle.textContent = '🌙';
darkModeToggle.style.cssText = 'position:fixed;top:20px;right:20px;background:none;border:none;font-size:24px;cursor:pointer;z-index:1000;';
darkModeToggle.onclick = () => {
    document.body.classList.toggle('dark-mode');
    darkModeToggle.textContent = document.body.classList.contains('dark-mode') ? '☀️' : '🌙';
    localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
};
document.body.appendChild(darkModeToggle);

// Check saved preference
if (localStorage.getItem('darkMode') === 'true') {
    document.body.classList.add('dark-mode');
    darkModeToggle.textContent = '☀️';
}
</script>
<style>
.dark-mode { background: #1a1a1a !important; color: #e0e0e0 !important; }
.dark-mode .container { background: #2a2a2a !important; }
</style>
<script>
// Simple tutorial
const tutorialSteps = [
    { selector: 'h1', text: 'Welcome! This is the main title.' },
    { selector: 'button', text: 'Click here to perform actions.' }
];
let currentStep = 0;
function showTutorial() {
    if (currentStep < tutorialSteps.length) {
        const step = tutorialSteps[currentStep];
        const el = document.querySelector(step.selector);
        if (el) {
            const tooltip = document.createElement('div');
            tooltip.textContent = step.text;
            tooltip.style.cssText = 'position:absolute;background:#6f42c1;color:white;padding:10px;border-radius:5px;z-index:1000;';
            el.style.position = 'relative';
            el.appendChild(tooltip);
            setTimeout(() => tooltip.remove(), 3000);
        }
        currentStep++;
    }
}
// Show tutorial on first visit
if (!localStorage.getItem('tutorial-shown')) {
    setTimeout(showTutorial, 1000);
    localStorage.setItem('tutorial-shown', 'true');
}
</script>
<script>
// Offline indicator
const offlineIndicator = document.createElement('div');
offlineIndicator.textContent = '⚠️ Offline';
offlineIndicator.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#ff6b6b;color:white;text-align:center;padding:5px;display:none;';
document.body.appendChild(offlineIndicator);
window.addEventListener('online', () => offlineIndicator.style.display = 'none');
window.addEventListener('offline', () => offlineIndicator.style.display = 'block');
</script>
<script>
// Offline indicator
const offlineIndicator = document.createElement('div');
offlineIndicator.textContent = '⚠️ Offline';
offlineIndicator.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#ff6b6b;color:white;text-align:center;padding:5px;display:none;';
document.body.appendChild(offlineIndicator);
window.addEventListener('online', () => offlineIndicator.style.display = 'none');
window.addEventListener('offline', () => offlineIndicator.style.display = 'block');
</script>
<script>
// Request notification permission
if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
}
function notify(title, body) {
    if (Notification.permission === 'granted') {
        new Notification(title, { body });
    }
}
</script>
<script>
// Keyboard shortcuts
document.addEventListener('keydown', (e) => {
    if (e.ctrlKey || e.metaKey) {
        switch(e.key) {
            case 's': e.preventDefault(); console.log('Save shortcut'); break;
            case 'r': e.preventDefault(); location.reload(); break;
            case 'f': e.preventDefault(); document.querySelector('input')?.focus(); break;
        }
    }
});
</script>
<script>
// Import from file
const importBtn = document.createElement('button');
importBtn.textContent = '📁 Import';
importBtn.onclick = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.onchange = (e) => {
        const file = e.target.files[0];
        const reader = new FileReader();
        reader.onload = (e) => {
            const textArea = document.querySelector('textarea');
            if (textArea) textArea.value = e.target.result;
        };
        reader.readAsText(file);
    };
    input.click();
};
document.querySelector('.container')?.appendChild(importBtn);
</script>
